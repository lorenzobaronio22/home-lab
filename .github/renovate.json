{
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "commitMessagePrefix": "chore(deps): ",
  "helm-values": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "helm-values"
      ],
      "matchFileNames": [
        "01.k3s-cluster/99.apps/homepage/values.yaml"
      ],
      "matchPackageNames": [
        "ghcr.io/gethomepage/homepage"
      ],
      "groupName": "homepage image"
    },
    {
      "matchManagers": [
        "helm-values"
      ],
      "matchFileNames": [
        "01.k3s-cluster/03.observability/dozzle/values.yaml"
      ],
      "matchPackageNames": [
        "amir20/dozzle"
      ],
      "groupName": "dozzle image"
    }
  ]
}