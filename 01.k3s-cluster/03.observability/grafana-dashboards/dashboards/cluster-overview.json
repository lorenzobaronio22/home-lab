{
  "uid": "homelab-cluster-overview",
  "title": "HomeLab - Cluster Overview",
  "tags": ["homelab", "kubernetes", "operations"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource_prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom"
        }
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource_prometheus"
        },
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ready Nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))) or (100 * sum(rate(container_cpu_usage_seconds_total{container!=\"\",namespace=~\"$namespace\"}[5m])) / clamp_min(sum(machine_cpu_cores), 1)) or vector(0)"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(container_memory_working_set_bytes{container!=\"\",namespace=~\"$namespace\"}) / sum(machine_memory_bytes)"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pod Restarts (rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[15m]))"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12}
    }
  ]
}
