{
  "uid": "homelab-longhorn-storage",
  "title": "HomeLab - Longhorn Storage",
  "tags": ["homelab", "longhorn", "storage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource_prometheus",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "PVC Used (%)",
      "datasource": {"type": "prometheus", "uid": "$datasource_prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "(100 * sum(kubelet_volume_stats_used_bytes) / clamp_min(sum(kubelet_volume_stats_capacity_bytes), 1)) or vector(0)"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PVCs Above 80% Used",
      "datasource": {"type": "prometheus", "uid": "$datasource_prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum((100 * kubelet_volume_stats_used_bytes / clamp_min(kubelet_volume_stats_capacity_bytes, 1)) > bool 80) or vector(0)"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "type": "table",
      "title": "Top PVC Utilization (%)",
      "datasource": {"type": "prometheus", "uid": "$datasource_prometheus"},
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "topk(20, 100 * (sum by (namespace, persistentvolumeclaim) (kubelet_volume_stats_used_bytes) / clamp_min(sum by (namespace, persistentvolumeclaim) (kubelet_volume_stats_capacity_bytes), 1))) or vector(0)"
        }
      ],
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8}
    }
  ]
}
