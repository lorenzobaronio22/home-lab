{
  "name": "homelab-cluster-ops-v1",
  "interval": "1m",
  "rules": [
    {
      "title": "NodeNotReadyCritical",
      "condition": "C",
      "for": "5m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "One or more Kubernetes nodes are not Ready"
      },
      "labels": {
        "severity": "critical",
        "scope": "cluster"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"false\"})",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [0],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    },
    {
      "title": "DeploymentUnavailableWarning",
      "condition": "C",
      "for": "10m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "One or more deployment replicas are unavailable"
      },
      "labels": {
        "severity": "warning",
        "scope": "apps"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "sum(kube_deployment_status_replicas_unavailable)",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [0],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    },
    {
      "title": "CrashLoopBackOffWarning",
      "condition": "C",
      "for": "10m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "CrashLoopBackOff detected in one or more containers"
      },
      "labels": {
        "severity": "warning",
        "scope": "apps"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "sum(kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\"})",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [0],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    },
    {
      "title": "PVCUsageHighWarning",
      "condition": "C",
      "for": "15m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "At least one PVC is above 85% usage"
      },
      "labels": {
        "severity": "warning",
        "scope": "storage"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "max(100 * kubelet_volume_stats_used_bytes / clamp_min(kubelet_volume_stats_capacity_bytes, 1))",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 900,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [85],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    },
    {
      "title": "PVCUsageVeryHighCritical",
      "condition": "C",
      "for": "10m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "At least one PVC is above 95% usage"
      },
      "labels": {
        "severity": "critical",
        "scope": "storage"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "max(100 * kubelet_volume_stats_used_bytes / clamp_min(kubelet_volume_stats_capacity_bytes, 1))",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [95],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    },
    {
      "title": "LogErrorRateWarning",
      "condition": "C",
      "for": "10m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "Error log rate is elevated"
      },
      "labels": {
        "severity": "warning",
        "scope": "logs"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__LOKI_DS_UID__",
          "model": {
            "expr": "sum(rate({namespace=~\".+\"} |~ \"(error|ERROR|exception|EXCEPTION|fatal|FATAL)\" [5m]))",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [0.01],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    }
  ]
}
