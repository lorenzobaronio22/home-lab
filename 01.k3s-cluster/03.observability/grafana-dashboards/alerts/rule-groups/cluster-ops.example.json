{
  "name": "homelab-cluster-ops",
  "interval": "1m",
  "rules": [
    {
      "title": "NodeNotReadyCritical",
      "condition": "C",
      "for": "5m",
      "noDataState": "NoData",
      "execErrState": "Error",
      "annotations": {
        "summary": "One or more Kubernetes nodes are not Ready"
      },
      "labels": {
        "severity": "critical",
        "scope": "cluster"
      },
      "data": [
        {
          "refId": "A",
          "datasourceUid": "__PROM_DS_UID__",
          "model": {
            "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"false\"})",
            "instant": true,
            "refId": "A"
          },
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          }
        },
        {
          "refId": "C",
          "datasourceUid": "__expr__",
          "model": {
            "conditions": [
              {
                "evaluator": {
                  "params": [0],
                  "type": "gt"
                },
                "operator": {
                  "type": "and"
                },
                "query": {
                  "params": ["A"]
                },
                "reducer": {
                  "params": [],
                  "type": "last"
                },
                "type": "query"
              }
            ],
            "refId": "C",
            "type": "classic_conditions"
          },
          "relativeTimeRange": {
            "from": 0,
            "to": 0
          }
        }
      ]
    }
  ]
}
